import numpy as np
import matplotlib.pyplot as plt

# ==============================================================================
# MCEWEN LABS: PROJECT 3 - EXERCISE 3.14 (GARCIA ALIGNMENT)
# SCHEME: ADAPTIVE RK4 - HIGH-ECCENTRICITY FLOWER PRECESSION
# ==============================================================================
# Purpose: Demonstrate orbital precession in a non-Newtonian gravity well.
# Specs: Polar Projection; K, U, and Constant Total E Landscape.
# ==============================================================================

GM = 4 * np.pi**2
ALPHA = 0.01  # Precession constant

def get_accel(r_vec):
    """The Modified Force Law Kernel: F = -(GMm/r^3) * (1 - alpha/r) * r"""
    r_mag = np.linalg.norm(r_vec)
    return -GM * (1 - ALPHA/r_mag) / r_mag**3 * r_vec

def adaptive_rk4_step(r, v, tau, tol=1e-9):
    """Adaptive Brain: Richardson Extrapolation for stiff solar encounters."""
    def rk4_jump(curr_r, curr_v, h):
        def derivs(cr, cv): return cv, get_accel(cr)
        k1r, k1v = derivs(curr_r, curr_v)
        k2r, k2v = derivs(curr_r + 0.5*h*k1r, curr_v + 0.5*h*k1v)
        k3r, k3v = derivs(curr_r + 0.5*h*k2r, curr_v + 0.5*h*k2v)
        k4r, k4v = derivs(curr_r + h*k3r, curr_v + h*k3v)
        return curr_r + (h/6.0)*(k1r + 2*k2r + 2*k3r + k4r), \
               curr_v + (h/6.0)*(k1v + 2*k2v + 2*k3v + k4v)

    r_big, v_big = rk4_jump(r, v, tau)
    r_mid, v_mid = rk4_jump(r, v, tau/2.0)
    r_small, v_small = rk4_jump(r_mid, v_mid, tau/2.0)
    
    error = np.linalg.norm(r_big - r_small)
    if error < tol:
        t_next = tau * (tol/error)**0.2 if error > 0 else tau * 2.0
        return r_small, v_small, t_next, True
    return r, v, tau * (tol/error)**0.2, False

# --- EXPERIMENTAL SETUP: TIGHT RADIUS FOR FLOWER EFFECT ---
# Using v = 2.0 AU/yr to force a deep perihelion dive into the sun.
r_state, v_state = np.array([1.0, 0.0]), np.array([0.0, 2.0])
tau, t, t_max = 0.001, 0, 4.0 

h_r, h_theta, h_ke, h_pe, h_tot, h_t = [], [], [], [], [], []

while t < t_max:
    r_mag = np.linalg.norm(r_state)
    ke = 0.5 * np.linalg.norm(v_state)**2
    pe = -GM / r_mag * (1 - ALPHA/(2*r_mag)) # Effective potential
    
    h_r.append(r_mag); h_theta.append(np.arctan2(r_state[1], r_state[0]))
    h_ke.append(ke); h_pe.append(pe); h_tot.append(ke + pe); h_t.append(t)
    
    r_state, v_state, tau, accepted = adaptive_rk4_step(r_state, v_state, tau)
    if accepted: t += tau

# --- VISUALIZATION: THE EXACT GARCIA SPEC ---
plt.style.use('dark_background')
fig = plt.figure(figsize=(16, 8), dpi=120)

# PLOT 1: POLAR FLOWER GEOMETRY
ax1 = fig.add_subplot(1, 2, 1, projection='polar')
ax1.plot(h_theta, h_r, color='cyan', linewidth=0.8, label='Precessing Path')
ax1.plot(0, 0, 'yo', markersize=15, label='Sun')
ax1.set_title("3.14: Polar Flower Orbit Precession", color='magenta', pad=20)
ax1.legend(loc='upper right')

# PLOT 2: ENERGY LANDSCAPE (The Constant E Proof)
ax2 = fig.add_subplot(1, 2, 2)
ax2.plot(h_t, h_ke, 'g-.', label='Kinetic (K)')
ax2.plot(h_t, h_pe, 'r--', label='Potential (U)')
ax2.plot(h_t, h_tot, 'w-', linewidth=2, label='Total Energy (E)')
ax2.set_title("3.14: Mechanical Energy Landscape", color='magenta')
ax2.set_xlabel("Time (Years)"); ax2.set_ylabel("Specific Energy")
ax2.legend(loc='center right'); ax2.grid(alpha=0.1)

plt.tight_layout()
plt.show()









