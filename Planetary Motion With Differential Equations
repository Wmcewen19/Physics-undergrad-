# Solar System Constant
GM = 4 * np.pi**2

def run_halley_final(v0, tau, total_years=160):
    """
    Final implementation using the extrapolated tau for 1% conservation.
    Simulates 160 years to capture exactly two perihelion passages.
    """
    n_steps = int(total_years / tau)
    t_axis = np.linspace(0, total_years, n_steps)
    
    # Pre-allocating data arrays
    r_pos = np.zeros((n_steps, 2))
    ke_hist, pe_hist, total_e_hist = np.zeros(n_steps), np.zeros(n_steps), np.zeros(n_steps)
    
    # INITIAL STATE: Halley at Aphelion (35 AU)
    r = np.array([35.0, 0.0])
    v = np.array([0.0, v0])

    for i in range(n_steps):
        r_mag = np.linalg.norm(r)
        
        # 1. Physics Snapshot
        ke = 0.5 * np.sum(v**2)
        pe = -GM / r_mag
        
        ke_hist[i] = ke
        pe_hist[i] = pe
        total_e_hist[i] = ke + pe
        r_pos[i] = r
        
        # 2. EULER-CROMER UPDATE (Velocity First)
        accel = -GM * r / r_mag**3
        v = v + tau * accel
        r = r + tau * v
        
    return t_axis, ke_hist, pe_hist, total_e_hist, r_pos

# --- EXECUTION: USING EXTRAPOLATED TAU ---
