plt.loglog(halley_v0, halley_tau_est, 'ro', markersize=12, label=f'Halley Estimate: {halley_tau_est:.4f}')

plt.title("3.6: Time-Step Extrapolation for Halley's Comet\nTarget: 1% Energy Conservation per Orbit", color='magenta')
plt.xlabel("Initial Velocity $v_0$ (AU/yr)"); plt.ylabel("Largest $\\tau$ (Years)")
plt.grid(True, which="both", ls="-", alpha=0.2)
