# SCHEME: RK4 VS. EULER-CROMER ENERGY COMPONENTS
# ==============================================================================

GM = 4 * np.pi**2

def get_derivs(state):
    x, y, vx, vy = state
    r_mag = np.sqrt(x**2 + y**2)
    return np.array([vx, vy, -GM*x/r_mag**3, -GM*y/r_mag**3])

def run_orbit(method, tau=0.015, total_years=160):
    n_steps = int(total_years / tau)
    state = np.array([35.0, 0.0, 0.0, 0.198]) # Halley Aphelion
    
    ke_hist, pe_hist, total_e_hist = [], [], []
    r_hist = []
    
    for i in range(n_steps):
        r_mag = np.linalg.norm(state[:2])
        v_sq = np.sum(state[2:]**2)
        
        ke = 0.5 * v_sq
        pe = -GM / r_mag
        
        r_hist.append(state[:2].copy())
        ke_hist.append(ke)
        pe_hist.append(pe)
        total_e_hist.append(ke + pe)
        
        if method == 'RK4':
            k1 = tau * get_derivs(state)
            k2 = tau * get_derivs(state + 0.5*k1)
            k3 = tau * get_derivs(state + 0.5*k2)
            k4 = tau * get_derivs(state + k3)
            state = state + (k1 + 2*k2 + 2*k3 + k4)/6.0
        else:
            accel = -GM * state[:2] / r_mag**3
            state[2:] += tau * accel
            state[:2] += tau * state[2:]
            
    return np.array(r_hist), np.array(ke_hist), np.array(pe_hist), np.array(total_e_hist)

# --- EXECUTION ---
tau_fair = 0.015
r_rk, ke_rk, pe_rk, e_rk = run_orbit('RK4', tau_fair)
r_ec, ke_ec, pe_ec, e_ec = run_orbit('EC', tau_fair)
t_axis = np.linspace(0, 160, len(e_rk))

