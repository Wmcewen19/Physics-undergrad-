GM = 4 * np.pi**2

def get_max_tau(v0, target_drift=0.01):
    """
    Finds the largest tau for a given v0 that keeps energy drift <= target_drift.
    """
    tau = 0.1  # Starting guess
    while True:
        # Run 1 orbit
        n_steps = int(200 / tau) # Ensure we cover a full period
        r = np.array([35.0, 0.0]); v = np.array([0.0, v0])
        e_init = 0.5 * v0**2 - GM/35.0
        
        max_drift = 0
        for _ in range(n_steps):
            r_mag = np.linalg.norm(r)
            accel = -GM * r / r_mag**3
            v += tau * accel
            r += tau * v
            e_now = 0.5 * np.sum(v**2) - GM/np.linalg.norm(r)
            max_drift = max(max_drift, abs((e_now - e_init)/e_init))
            
        if max_drift <= target_drift:
            return tau
        tau *= 0.8 # Shrink tau until we hit the conservation target

# --- STEP 1: GATHER TRIAL DATA (1.0 TO 0.5 AU/yr) ---
v_trials = np.array([1.0, 0.9, 0.8, 0.7, 0.6, 0.5])
tau_results = [get_max_tau(v) for v in v_trials]

# --- STEP 2: LOG-LOG EXTRAPOLATION FOR HALLEY (v0 = 0.198) ---
coeffs = np.polyfit(np.log(v_trials), np.log(tau_results), 1)
