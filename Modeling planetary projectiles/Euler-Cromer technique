# EXERCISE 3 problem 3.14: # PROBLEM 3.14 - ADAPTIVE ORBITAL PRECESSION (POLAR)
# Force Law: F = -(GMm/r^3) * (1 - alpha/r) * r
# ==============================================================================
import numpy as np
import matplotlib.pyplot as plt


GM = 4 * np.pi**2
ALPHA = 0.01  # Constant for physical precession per class notes

def get_accel(r_vec, alpha):
    """The Non-Newtonian Gravity Kernel."""
    r_mag = np.linalg.norm(r_vec)
    # Applying the (1 - alpha/r) correction factor
    return -GM * (1 - alpha / r_mag) / r_mag**3 * r_vec

def rk4_step(r, v, tau, alpha):
    """Standard 4th-Order jump for the adaptive comparison."""
    def derivs(curr_r, curr_v):
        return curr_v, get_accel(curr_r, alpha)

    k1r, k1v = derivs(r, v)
    k2r, k2v = derivs(r + 0.5*tau*k1r, v + 0.5*tau*k1v)
    k3r, k3v = derivs(r + 0.5*tau*k2r, v + 0.5*tau*k2v)
    k4r, k4v = derivs(r + tau*k3r, v + tau*k3v)

    r_next = r + (tau/6.0) * (k1r + 2*k2r + 2*k3r + k4r)
    v_next = v + (tau/6.0) * (k1v + 2*k2v + 2*k3v + k4v)
    return r_next, v_next

def adaptive_engine(r, v, tau, alpha, tol=1e-8):
    """THE ADAPTIVE BRAIN: Efficiency is king here."""
    r_big, v_big = rk4_step(r, v, tau, alpha)
    r_mid, v_mid = rk4_step(r, v, tau/2.0, alpha)
    r_small, v_small = rk4_step(r_mid, v_mid, tau/2.0, alpha)
    
    error = np.linalg.norm(r_big - r_small)
    
    if error < tol:
        r_next, v_next = r_small, v_small
        tau_next = tau * (tol / error)**0.2 if error > 0 else tau * 2.0
        return r_next, v_next, tau_next, True
    else:
        tau_next = tau * (tol / error)**0.2
        return r, v, tau_next, False

# --- SIMULATION SETUP ---
r = np.array([1.0, 0.0]) # Starting at Aphelion
v = np.array([0.0, 4.0]) 
tau, t, t_max = 0.01, 0, 50 # Reduced t_max for a cleaner flower plot
history = []

while t < t_max:
    history.append(r.copy())
    r, v, tau, accepted = adaptive_engine(r, v, tau, ALPHA)
    if accepted:
        t += tau

history = np.array(history)

# --- POLAR CONVERSION ---
r_coords = np.sqrt(history[:,0]**2 + history[:,1]**2)
theta_coords = np.arctan2(history[:,1], history[:,0])

# --- PLOTTING ---
plt.style.use('dark_background')
fig = plt.figure(figsize=(10, 10))
ax = fig.add_subplot(1, 1, 1, projection='polar')

ax.plot(theta_coords, r_coords, color='cyan', linewidth=0.7, label='Precessing Path')
ax.plot(0, 0, 'yo', markersize=15, label='Sun')

# Theoretical Precession Calculation
# Specific L = r x v (effectively r x p since m=1)
L = np.linalg.norm(np.cross(np.append(history[0], 0), np.append([0, 4.0], 0)))
a_theory = np.sqrt(1 + (GM * ALPHA) / L**2)
precession_deg = abs(360 * (1 - a_theory) / a_theory)

ax.set_title(f"3.14: Polar Precession (Flower Orbit)\nPredicted Precession: {precession_deg:.2f}° / rev", 
             color='magenta', fontsize=14, pad=20)
ax.legend(loc='upper right')
plt.show()






























# ==============================================================================
# EXERSIZE 4 problem 3.15 - THE SPIRAL OF DEATH (ADAPTIVE RK4 WITH DRAG)
# Purpose: To demonstrate orbital decay and the paradox of increasing 
# average kinetic energy in a dissipative central force system.
# ==============================================================================

import numpy as np
import matplotlib.pyplot as plt



# --- Physical Constants (Gaussian Units) ---
GM = 4 * np.pi**2  # Gravitational Parameter for Solar System (AU^3/yr^2)

# --- Initial Conditions (Halley-like Ellipse) ---
r = np.array([1.0, 0.0])   # Starting at 1 AU
v = np.array([0.0, 4.0])   # Initial velocity (AU/yr) - Elliptical velocity
r_mag0 = np.linalg.norm(r)
v_mag0 = np.linalg.norm(v)

# --- The Death Constant (C) ---
# Prompt Requirement: Set C such that |Fg| = 100 * |Fd| at t=0
# Calculation: (GM/r^2) = 100 * C * v^2
C_DRAG = (GM / r_mag0**2) / (100 * v_mag0**2)

def get_accel(r_vec, v_vec):
    """
    MODULAR PHYSICS KERNEL:
    Calculates the combined acceleration of Gravity and Drag.
    F_drag = -C * |v| * v (Velocity-squared drag law)
    """
    r_mag = np.linalg.norm(r_vec)
    v_mag = np.linalg.norm(v_vec)
    
    # 1. Newtonian Gravity (Conservative)
    a_grav = -GM / r_mag**3 * r_vec
    
    # 2. Atmospheric/Interplanetary Drag (Non-Conservative)
    # This force always acts opposite to the velocity vector.
    a_drag = -C_DRAG * v_mag * v_vec
    
    return a_grav + a_drag

def rk4_step(r, v, tau):
    """
    4th-ORDER RUNGE-KUTTA INTEGRATOR:
    Advances the state (r, v) by one time-step tau.
    """
    def derivs(curr_r, curr_v):
        return curr_v, get_accel(curr_r, curr_v)
        
    k1r, k1v = derivs(r, v)
    k2r, k2v = derivs(r + 0.5*tau*k1r, v + 0.5*tau*k1v)
    k3r, k3v = derivs(r + 0.5*tau*k2r, v + 0.5*tau*k2v)
    k4r, k4v = derivs(r + tau*k3r, v + tau*k3v)
    
    r_next = r + (tau/6.0) * (k1r + 2*k2r + 2*k3r + k4r)
    v_next = v + (tau/6.0) * (k1v + 2*k2v + 2*k3v + k4v)
    return r_next, v_next

def adaptive_engine(r, v, tau, tol=1e-8):
    """
    THE ADAPTIVE BRAIN:
    Compares 1 big step vs 2 half-steps to estimate local error.
    Essential for 'stiff' problems where velocity changes rapidly.
    """
    # 1. Take one full step of size tau
    r_big, v_big = rk4_step(r, v, tau)
    
    # 2. Take two half-steps of size tau/2
    r_mid, v_mid = rk4_step(r, v, tau/2.0)
    r_small, v_small = rk4_step(r_mid, v_mid, tau/2.0)
    
    # 3. Compute relative error (Richardson Extrapolation logic)
    error = np.linalg.norm(r_big - r_small)
    
    if error < tol:
        # Step accepted! Scale tau up for efficiency if error is low.
        tau_next = tau * (tol / error)**0.2 if error > 0 else tau * 2.0
        return r_small, v_small, tau_next, True
    else:
        # Step rejected. Shrink tau and retry the same point.
        tau_next = tau * (tol / error)**0.2
        return r, v, tau_next, False

# --- SIMULATION LOOP ---
tau, t, t_max = 0.01, 0, 15  # Starting tau, current time, max years
history = []
ke_history = []
t_history = []

while t < t_max:
    # Record state for analysis
    history.append(r.copy())
    ke_history.append(0.5 * np.linalg.norm(v)**2) # Kinetic Energy (m=1)
    t_history.append(t)
    
    # Call the adaptive engine to advance the state
    r, v, tau, accepted = adaptive_engine(r, v, tau)
    if accepted:
        t += tau
    
    # CRASH CONDITION: Stopping the simulation if we impact the Sun's surface
    if np.linalg.norm(r) < 0.02:
        print(f"Impact! The comet has fallen after {t:.2f} years.")
        break

history = np.array(history)

# --- PLOTTING & VISUALIZATION ---
plt.style.use('dark_background')
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 7))

# Plot 1: The Spiral Trajectory
ax1.plot(history[:,0], history[:,1], color='orange', linewidth=0.7, label='Decaying Path')
ax1.plot(0, 0, 'yo', markersize=15, label='Sun')
ax1.set_xlabel("x-Coordinate (AU)", fontsize=12)
ax1.set_ylabel("y-Coordinate (AU)", fontsize=12)
ax1.set_title("3.15: The Orbital Spiral of Death", color='orange', fontsize=14)
ax1.set_aspect('equal')
ax1.legend()

# Plot 2: Kinetic Energy Paradox
ax2.plot(t_history, ke_history, color='lime', linewidth=1.2)
ax2.set_xlabel("Time (Years)", fontsize=12)
ax2.set_ylabel("Kinetic Energy (AU²/yr²)", fontsize=12)
ax2.set_title("Paradox: Average Kinetic Energy vs. Time", color='lime', fontsize=14)
ax2.grid(alpha=0.1)

plt.tight_layout()
plt.show()
