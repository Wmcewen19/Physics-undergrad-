import numpy as np
import matplotlib.pyplot as plt

# ==============================================================================
# Lab Notes: THE RK4 PRECISION ENGINE
# ------------------------------------------------------------------------------
# OBJECTIVE: Upgrade the Halley's Comet simulation from Euler-Cromer to 
# 4th-Order Runge-Kutta. I want to see if this 'scouting' method can handle 
# the high-speed slingshot at perihelion better than my previous setup.
#
# UNITS: Distance = AU | Time = Years | GM = 4*pi^2 (Solar mass units)
# ==============================================================================
GM = 4 * np.pi**2 

def get_derivs(state):
    """
    THE PHYSICS KERNEL: This is the brain of the gravity simulator.
    It takes my current state [x, y, vx, vy] and spits out the 
    derivatives [vx, vy, ax, ay]. 
    
    FUTURE NOTE: If I ever want to simulate a different planet or 
    even a black hole, I just need to swap out the acceleration (ax, ay) 
    math right here.
    """
    x, y, vx, vy = state
    r_mag = np.sqrt(x**2 + y**2) # Distance from the Sun
    
    # Standard Inverse-Square Law: a = -GM/r^2 (broken into components)
    ax = -GM * x / r_mag**3
    ay = -GM * y / r_mag**3
    
    return np.array([vx, vy, ax, ay])

def rk4_step(state, tau):
    """
    THE 'FOUR SCOUTS' METHOD: This is what makes RK4 the gold standard.
    Instead of just guessing where the comet goes next, I send out 4 'scouts' 
    at different points along the curve to see how the gravity energy changes.
    
    k1 = Start of the step
    k2 & k3 = Midpoints (these get double weight because they are usually most accurate)
    k4 = End of the step
    """
    k1 = tau * get_derivs(state)
    k2 = tau * get_derivs(state + 0.5 * k1)
    k3 = tau * get_derivs(state + 0.5 * k2)
    k4 = tau * get_derivs(state + k3)
    
    # We combine them with a weighted average to get the final surgical precision.
    return state + (k1 + 2*k2 + 2*k3 + k4) / 6.0

def run_rk4_sim(v0, tau, total_years=500):
    """
    THE SIMULATION LOOP: Runs the orbit for several centuries to check for drift.
    """
    n_steps = int(total_years / tau)
    # Starting at Aphelion (35 AU away, moving at its slowest)
    state = np.array([35.0, 0.0, 0.0, v0]) 
    
    pos_history = np.zeros((n_steps, 2))
    energy_history = np.zeros(n_steps)
    
    # Grab initial energy for the final drift calculation
    e_init = 0.5 * (state[2]**2 + state[3]**2) - GM / 35.0

    for i in range(n_steps):
        pos_history[i] = state[:2]
        r_mag = np.sqrt(state[0]**2 + state[1]**2)
        # Record the total energy (Kinetic + Potential) to see if the math 'leaks'
        energy_history[i] = 0.5 * (state[2]**2 + state[3]**2) - GM / r_mag
        
        # Take the surgical RK4 jump
        state = rk4_step(state, tau)
        
    drift = abs((energy_history[-1] - e_init) / e_init) * 100
    return pos_history, energy_history, drift

# ==============================================================================
# EXPERIMENT EXECUTION
# ------------------------------------------------------------------------------
# Using tau = 0.005. I'm keeping this the same as my 3.6 run so I can 
# compare the precision of RK4 vs Euler-Cromer fairly.
# ==============================================================================
v0_h = 0.198 # Halley's velocity at aphelion
tau_h = 0.005 

pos, energy, drift_val = run_rk4_sim(v0_h, tau_h)

# ==============================================================================
# VISUALIZATION: THE POLAR MASTERPIECE
# ------------------------------------------------------------------------------
# I'm using a Polar projection because it makes the orbital geometry 
# much easier to visualize than standard X/Y plots.
# ==============================================================================
plt.style.use('dark_background')
fig = plt.figure(figsize=(12, 6))

# Convert the Cartesian results to Polar (Radius and Angle)
r_vals = np.sqrt(pos[:,0]**2 + pos[:,1]**2)
theta_vals = np.arctan2(pos[:,1], pos[:,0])

# Plot 1: Polar Orbital Path
ax1 = fig.add_subplot(1, 2, 1, projection='polar')
ax1.plot(theta_vals, r_vals, color='magenta', linewidth=1, label='RK4 Trajectory')
ax1.plot(0, 0, 'yo', markersize=10, label='Sun') # The Sun at the center (origin)
ax1.set_title("Polar Orbital Geometry", color='cyan', fontsize=14)
ax1.grid(True, alpha=0.3)

# Plot 2: Energy Monitor
# If this is a flat line, I've successfully 'tricked' the machine into 
# respecting the laws of physics.
ax2 = fig.add_subplot(1, 2, 2)
time_axis = np.linspace(0, 500, len(energy))
ax2.plot(time_axis, energy, color='lime')
ax2.set_title(f"RK4 Energy Stability (Drift: {drift_val:.2e}%)", color='cyan', fontsize=14)
ax2.set_xlabel("Years", fontsize=12)
ax2.set_ylabel("Total Energy", fontsize=12)

