import numpy as np
import matplotlib.pyplot as plt

# ==============================================================================
# Lab Notes: THE RK4 REDEMPTION (3.11)
# Goal: Compare RK4 vs Euler-Cromer at a "Fair" resolution.
# Units: Distance=AU, Time=Years. GM = 4*pi^2.
# ==============================================================================
GM = 4 * np.pi**2 

def get_derivs(state):
    """The Physics Core: [x, y, vx, vy] -> [vx, vy, ax, ay]"""
    x, y, vx, vy = state
    r_mag = np.sqrt(x**2 + y**2)
    ax, ay = -GM * x / r_mag**3, -GM * y / r_mag**3
    return np.array([vx, vy, ax, ay])

def rk4_step(state, tau):
    """The Surgical 4th-Order Scout Method."""
    k1 = tau * get_derivs(state)
    k2 = tau * get_derivs(state + 0.5 * k1)
    k3 = tau * get_derivs(state + 0.5 * k2)
    k4 = tau * get_derivs(state + k3)
    return state + (k1 + 2*k2 + 2*k3 + k4) / 6.0

def ec_step(state, tau):
    """The Stable 1st-Order Symplectic Method."""
    x, y, vx, vy = state
    r_mag = np.sqrt(x**2 + y**2)
    # Velocity FIRST, then position
    vx_new = vx + tau * (-GM * x / r_mag**3)
    vy_new = vy + tau * (-GM * y / r_mag**3)
    x_new = x + tau * vx_new
    y_new = y + tau * vy_new
    return np.array([x_new, y_new, vx_new, vy_new])

def run_experiment(method, tau_val, total_years=500):
    n_steps = int(total_years / tau_val)
    state = np.array([35.0, 0.0, 0.0, 0.198]) # Halley Aphelion
    
    pos_history = np.zeros((n_steps, 2))
    energy_history = np.zeros(n_steps)
    e_init = 0.5 * (0.198**2) - GM / 35.0

    for i in range(n_steps):
        pos_history[i] = state[:2]
        r_mag = np.sqrt(state[0]**2 + state[1]**2)
        energy_history[i] = 0.5 * (state[2]**2 + state[3]**2) - GM / r_mag
        
        if method == 'RK4':
            state = rk4_step(state, tau_val)
        else:
            state = ec_step(state, tau_val)
            
    drift = abs((energy_history[-1] - e_init) / e_init) * 100
    return pos_history, energy_history, drift

# ==============================================================================
# EXECUTION: PROVING THE SUPERIORITY
# We are using tau = 0.015. This is the "Sweet Spot."
# ==============================================================================
tau_fair = 0.005 

rk4_pos, rk4_e, rk4_drift = run_experiment('RK4', tau_fair)
ec_pos, ec_e, ec_drift = run_experiment('EC', tau_fair)

