coeff = kappa * tau / h**2
x = (np.arange(1, N + 1) - 1.5) * h - L/2
tt = np.zeros(N)

# Automaticaly find the index closest to your x0 setting
# This ensures conservation of energy by using 1/h for the spike amplitude.
