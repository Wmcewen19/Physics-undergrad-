# OBJECTIVE: Find the 'Numerical Breaking Point' of the 1D Diffusion Equation.
# We center the rod at 0 so the boundaries sit at +/- 0.5.
# ==============================================================================

def run_trial(tau, N=61, kappa=1.0, L=1.0, nstep=300):
    """The Core Marching Engine: Forward Time, Centered Space."""
    h = L / (N - 1)
    coeff = kappa * tau / h**2
    
    x_axis = np.linspace(-L/2, L/2, N) 
    tt = np.zeros(N)
    
    # Delta spike at x=0 (Index 30 for N=61)
    center_idx = int((N - 1) / 2)
    tt[center_idx] = 1.0 / h 
    
    for _ in range(nstep):
        # Update interior points; skip ends (Dirichlet B.C.s = 0)
        tt[1:-1] = tt[1:-1] + coeff * (tt[2:] + tt[0:-2] - 2*tt[1:-1])
        
    return x_axis, tt, coeff

def plot_individual(x, tt, tau, c, trial_num):
    """Plotting logic for isolated trials."""
    plt.style.use('dark_background')
    plt.figure(figsize=(8, 5))
    plt.plot(x, tt, color='cyan', label=f'Tau={tau}')
    plt.title(f"Trial {trial_num}: Stability Check (Coeff={c:.3f})")
    plt.xlabel("Position (x)")
    plt.ylabel("Temperature (T)")
    plt.grid(alpha=0.2)
    plt.legend()
    plt.show()

# --- INDIVIDUAL EXECUTION BLOCKS ---

# Trial 1: High Precision (Stable) [cite: 281]
x1, res1, c1 = run_trial(1e-5)
plot_individual(x1, res1, 1e-5, c1, 1)

# Trial 2: Stable Spread [cite: 281]
x2, res2, c2 = run_trial(5e-5)
plot_individual(x2, res2, 5e-5, c2, 2)

# Trial 3: Boundary Limit (Stable) [cite: 281]
x3, res3, c3 = run_trial(1e-4)
plot_individual(x3, res3, 1e-4, c3, 3)

# Trial 4: The Breaking Point (Unstable)
x4, res4, c4 = run_trial(5e-4)
plot_individual(x4, res4, 5e-4, c4, 4)

# Trial 5: Total Meltdown (Unstable)
x5, res5, c5 = run_trial(1e-3)
plot_individual(x5, res5, 1e-3, c5, 5)

# --- MASTER OVERLAY SCRIPT ---
tau_list = [1e-5, 5e-5, 1e-4, 5e-4, 1e-3]
plt.figure(figsize=(12, 7))

for i, t_val in enumerate(tau_list):
    x_master, results_master, s_coeff = run_trial(t_val)
    # Using r"..." to fix the LaTeX escape sequence warning
    plt.plot(x_master, results_master, label=f"Trial {i+1}: $\\tau$={t_val} (C={s_coeff:.3f})")

plt.title(r"Project 4 Master Sweep: $x \in [-0.5, 0.5]$ Stability Analysis", color='cyan')
plt.xlabel("Position (x)")
