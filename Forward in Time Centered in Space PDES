    # FTCS Vectorized Interior Update
    tt[1:-1] = tt[1:-1] + coeff * (tt[2:] + tt[0:-2] - 2*tt[1:-1])
    
    # PERIODIC BOUNDARY CONDITIONS (The "Portal" Logic)
    # The ghost cells must mirror the interior edges seamlessy.
    tt[0] = tt[-2]   # Left portal link ( ghost 0 -> real N-2 )
