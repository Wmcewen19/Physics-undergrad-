import numpy as np
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D

# ==============================================================================
# MCEWEN LABS: PROJECT 4 - EXERCISE 6.9 (DUFORT-FRANKEL)
# ------------------------------------------------------------------------------
# NOTE: This is an UNCONDITIONALLY STABLE explicit scheme.
# It uses the "Leap-Frog" method to avoid the stability Breakdown.
# ==============================================================================

# --- PARAMETER BLOCK ---
N = 61               
tau = 1.0e-4         # Use 1e-4 for the seeding step to ensure stability
L, kappa = 1.0, 1.0 
nstep = 1500         
nplots = 50          
# -----------------------

h = L / (N - 1)
# alpha calculation
alpha = (kappa * tau) / (h**2)
x = np.linspace(-L/2, L/2, N)

# Three time levels: Past (n-1), Current (n), Next (n+1)
tt_past = np.zeros(N)
tt_curr = np.zeros(N)
tt_next = np.zeros(N)

# 1. INITIAL CONDITION (Time level: n-1)
# Using a very narrow Gaussian for a stable start
sigma0 = 0.02
tt_past = (1.0 / (sigma0 * np.sqrt(2 * np.pi))) * np.exp(-x**2 / (2 * sigma0**2))

# 2. SEEDING STEP (Using FTCS to get Time level: n)
# "FTCS scheme on the first step to get it started"
tt_curr[1:-1] = tt_past[1:-1] + alpha * (tt_past[2:] + tt_past[0:-2] - 2*tt_past[1:-1])

# Pre-calculate DuFort-Frankel coefficients
# C1 = (1-2a)/(1+2a) and C2 = 2a/(1+2a)
c1 = (1.0 - 2.0*alpha) / (1.0 + 2.0*alpha)
c2 = (2.0*alpha) / (1.0 + 2.0*alpha)

# Storage
ttplot = np.zeros((N, nplots))
tplot = np.zeros(nplots)
plot_step = max(1, nstep // nplots)

print(f"--- DUFORT-FRANKEL SYSTEM REPORT ---")
print(f"Alpha: {alpha:.4f} | Starting Leap-Frog...")

# --- MAIN PHYSICS LOOP ---
for istep in range(nstep):
    # DuFort-Frankel Update Rule
    tt_next[1:-1] = c1 * tt_past[1:-1] + c2 * (tt_curr[2:] + tt_curr[0:-2])
    
    # Boundary Conditions (Cold Walls)
    tt_next[0] = 0; tt_next[-1] = 0
    
    # Snapshot storage
    if (istep % plot_step) == 0:
        iplot = istep // plot_step
        if iplot < nplots:
            ttplot[:, iplot] = tt_curr
            tplot[iplot] = istep * tau
            
    # Cycle the time levels
    tt_past = np.copy(tt_curr)
    tt_curr = np.copy(tt_next)

# --- VISUALIZATION ---
fig = plt.figure(figsize=(15, 7))
ax1 = fig.add_subplot(121, projection='3d')
T_m, X_m = np.meshgrid(tplot, x)
ax1.plot_surface(X_m, T_m, ttplot, cmap='plasma', edgecolor='black', linewidth=0.1)
ax1.set_title("3D Surface: Stable DuFort-Frankel")

ax2 = fig.add_subplot(122)
cp = ax2.contour(tplot, x, ttplot, levels=[0.2, 0.5, 1, 2, 5], colors='black')
ax2.clabel(cp, inline=True, fontsize=9, fmt='%1.1f')
ax2.set_title("Stable Temperature Contours")
plt.tight_layout()
plt.show()

# Final conservation proof
print(f"Final Heat Conservation Check: {np.sum(tt_curr)*h:.4f}")
