import numpy as np
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D

# ==============================================================================
# MCEWEN LABS: PROJECT 4 - HEAT DIFFUSION ENGINE (GARCIA 6.3)
# ------------------------------------------------------------------------------
# NOTE TO SELF: This is the baseline FTCS (Forward Time Centered Space) solver.
# We are simulating how a single "pulse" of heat spreads in a 1D rod.
# OBJECTIVE: Find the 'Numerical Breaking Point' of the 1D Diffusion Equation.
# We center the rod at 0 so the boundaries sit at +/- 0.5.
# ==============================================================================

# --- PARAMETER BLOCK (The Knobs and Dials) ---
N = 61               # Grid resolution. Stability "cliff" is at N=101.
tau = 1.0e-4         # Time step. If tau > 1.38e-4, the math explodes.
L, kappa = 1.0, 1.0  # Length of rod and Thermal Diffusivity constant.
nstep = 1500         # How long to let the simulation run.
nplots = 50          # How many "snapshots" to save for the 3D mesh.
# ---------------------------------------------

# --- SETUP THE UNIVERSE ---
h = L / (N - 1)              # Distance between grid points.
coeff = kappa * tau / h**2   # THE STABILITY COEFF. MUST BE <= 0.5!
x = np.linspace(-L/2, L/2, N)# Create the physical x-axis from -0.5 to 0.5.

# Initialize Temperature array 'tt' with all zeros.
tt = np.zeros(N)
# Place the initial "Spike" (Delta Function) in the dead center.
# We divide by h so the "Area" under the spike equals 1.0 (Conservation of Energy).
tt[int(N/2)] = 1.0 / h 

# --- DATA ARCHIVE FOR PLOTTING ---
# We store results in 'ttplot' matrix: Rows = Position, Columns = Time Snapshots.
ttplot = np.zeros((N, nplots))
tplot = np.zeros(nplots)
plot_step = nstep / nplots

# --- MAIN PHYSICS LOOP (The Evolution) ---
print(f"STABILITY REPORT: Coeff is {coeff:.4f}")

for istep in range(nstep):
    
    # THE FTCS CORE: This is the vectorized version of Garcia's loop.
    # New Temp = Old Temp + Coeff * (Temp_Right + Temp_Left - 2*Temp_Center)
    # We only update 1 to -1 because the ends (0 and -1) are fixed by boundaries.
    tt[1:-1] = tt[1:-1] + coeff * (tt[2:] + tt[0:-2] - 2*tt[1:-1])
    
    # DIRICHLET BOUNDARY CONDITIONS:
    # Both ends of the rod are stuck in ice (T = 0).
    tt[0] = 0; tt[-1] = 0 
    
    # SNAPSHOT LOGIC: Every few steps, save the current state to our 2D array.
    if (istep % plot_step) < 1:
        iplot = int(istep / plot_step)
        if iplot < nplots:
            ttplot[:, iplot] = tt
            tplot[iplot] = istep * tau

# --- THE DUAL-VISUAL INTERFACE ---
fig = plt.figure(figsize=(14, 7))

# 1. THE 3D SURFACE (The "Tent")
# This shows the temperature 'melting' over time.
ax1 = fig.add_subplot(121, projection='3d')
T_mesh, X_mesh = np.meshgrid(tplot, x)
ax1.plot_surface(X_mesh, T_mesh, ttplot, cmap='viridis', edgecolor='black', linewidth=0.1)
ax1.set_title("3D Diffusion Surface")
ax1.set_zlabel("Temperature T(x,t)")

# 2. THE CONTOUR PLOT (The "Ripples")
# This is Figure 6.7 in Garcia. Top-down view of the heat spreading.
ax2 = fig.add_subplot(122)
# Levels: We start at 1.0 to keep the plot clean and avoid crowded labels at t=0.
levels = [1, 2, 3, 4, 5, 6, 8, 10] 
cp = ax2.contour(tplot, x, ttplot, levels=levels, colors='black')
# fmt='%1.0f' keeps the labels as whole numbers.
ax2.clabel(cp, inline=True, fontsize=9, fmt='%1.0f')

ax2.set_title("2D Temperature Contours")
ax2.set_xlabel("Time"); ax2.set_ylabel("Position (x)")
ax2.set_xlim(0, 0.03) # Focusing on the early diffusion window.

plt.tight_layout()
plt.show()









import numpy as np
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D

# ==============================================================================
# MCEWEN LABS: PROJECT 4 - INSULATED BOUNDARIES (GARCIA 6.6)
# ------------------------------------------------------------------------------
# NOTE TO SELF: This uses NEUMANN boundary conditions (T' = 0).
# Heat cannot escape the rod; it just reflects off the ends like a mirror.
# ==============================================================================

# --- PARAMETER BLOCK ---
N = 61               # Grid resolution.
tau = 1.0e-4         # Time step. 
L, kappa = 1.0, 1.0  
nstep = 1500         
nplots = 50          
# -----------------------

# --- STAGGERED GRID SETUP ---
# In 6.6, we use (N-2) for spacing so the boundaries fall between points.
h = L / (N - 2)              
coeff = kappa * tau / h**2   

# Staggered x-axis logic: ensures boundaries are at +/- L/2
x = (np.arange(1, N + 1) - 1.5) * h - L/2

tt = np.zeros(N)
tt[int(N/2)] = 1.0 / h # Centered Delta Spike

# Storage for the 3D visual
ttplot = np.zeros((N, nplots))
tplot = np.zeros(nplots)
plot_step = nstep / nplots

# --- MAIN PHYSICS LOOP ---
print(f"STABILITY REPORT (6.6): Coeff is {coeff:.4f}")

for istep in range(nstep):
    
    # Interior update (Same math as 6.3)
    tt[1:-1] = tt[1:-1] + coeff * (tt[2:] + tt[0:-2] - 2*tt[1:-1])
    
    # NEUMANN BOUNDARY CONDITIONS (The "Mirror" Logic):
    # Instead of T=0, we set the ghost point equal to its neighbor.
    # This forces the slope (flux) at the boundary to be zero.
    tt[0] = tt[1]     # Left boundary reflection
    tt[-1] = tt[-2]   # Right boundary reflection
    
    if (istep % plot_step) < 1:
        iplot = int(istep / plot_step)
        if iplot < nplots:
            ttplot[:, iplot] = tt
            tplot[iplot] = istep * tau

# --- THE DUAL-VISUAL INTERFACE ---
fig = plt.figure(figsize=(14, 7))

# 1. 3D Mesh
ax1 = fig.add_subplot(121, projection='3d')
T_mesh, X_mesh = np.meshgrid(tplot, x)
ax1.plot_surface(X_mesh, T_mesh, ttplot, cmap='plasma', edgecolor='black', linewidth=0.1)
ax1.set_title("3D Surface: Insulated Rod (6.6)")
ax1.set_zlabel("Temperature T(x,t)")

# 2. Contour Plot
ax2 = fig.add_subplot(122)
levels = [1, 2, 3, 4, 5, 6, 8, 10] 
cp = ax2.contour(tplot, x, ttplot, levels=levels, colors='black')
ax2.clabel(cp, inline=True, fontsize=9, fmt='%1.0f')

ax2.set_title("Temperature Contour (Neumann)")
ax2.set_xlabel("Time"); ax2.set_ylabel("Position (x)")
ax2.set_xlim(0, 0.03)

plt.tight_layout()
plt.show()

# Verification: Total heat should stay constant (Sum of tt * h)
total_heat = np.sum(tt[1:-1]) * h
print(f"Conservation Check: Total Heat = {total_heat:.4f}")









