import numpy as np
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D

# --- 1. The Möbius Winding Core ---
R, r_minor = 3.0, 0.4
num_windings = 30 
pts = np.linspace(0, 4*np.pi, 1000) # Full Möbius traversal

# Parametric path for the wire
x_wire = (R + r_minor * np.cos(pts/2)) * np.cos(pts)
y_wire = (R + r_minor * np.cos(pts/2)) * np.sin(pts)
z_wire = r_minor * np.sin(pts/2)

# --- 2. The Interference Analysis (The "Telling" Part) ---
# We pick a few points to show the cancellation clearly
u_samples = np.linspace(0, 2*np.pi, 12, endpoint=False)

fig = plt.figure(figsize=(12, 10), facecolor='white')
ax = fig.add_subplot(111, projection='3d')

# Plot the physical wire (Gold)
ax.plot(x_wire, y_wire, z_wire, color='#D4AF37', lw=1, alpha=0.6, label='Winding Path')

# Plot Opposing Vectors at Sample Points
for u in u_samples:
    # Vector 1: Current flowing 'forward'
    x1 = (R + r_minor * np.cos(u/2)) * np.cos(u)
    y1 = (R + r_minor * np.cos(u/2)) * np.sin(u)
    z1 = r_minor * np.sin(u/2)
    
    # Vector 2: The same wire 2*pi later (the 'other side' of the twist)
    u2 = u + 2*np.pi
    x2 = (R + r_minor * np.cos(u2/2)) * np.cos(u2)
    y2 = (R + r_minor * np.cos(u2/2)) * np.sin(u2)
    z2 = r_minor * np.sin(u2/2)
    
    # Magnetic Field Direction (Approx)
    # Side A (Red) vs Side B (Blue) - These will point OPPOSITE
    ax.quiver(x1, y1, z1, -np.sin(u), np.cos(u), 0, color='crimson', length=0.6, lw=2)
    ax.quiver(x2, y2, z2, np.sin(u), -np.cos(u), 0, color='royalblue', length=0.6, lw=2)

# --- 3. Aesthetics ---
ax.view_init(elev=35, azim=45)
ax.set_axis_off()
plt.title("Wound Möbius Inductor: Spatial Field Cancellation\nRed/Blue vectors prove destructive B-field interference", 
          fontsize=14, family='serif', pad=20)

plt.show()
