# =============================================================================
# MCEWEN LABS: PROJECT 5 - EXERCISE 7.4 (PART A)
# SCHEME: LAX METHOD (FIRST-ORDER STABILIZATION)
# =============================================================================
# Purpose: To solve the 1-D Transport Equation using the Lax Method,
# utilizing the 'advect' routine logic found in Garcia (Chapter 7).
# =============================================================================

def main():
    # --- Numerical Parameters ---
    N = 60                # Grid points
    L = 1.0               # Domain length
    x = np.linspace(0, L, N)
    h = L / (N - 1)
    c = 1.0               # Wave speed
    tau = 0.012           # Time step
    coeff = c * tau / h   # Courant number
    omega = 10 * np.pi    # Driving frequency
    
    # --- Initialization ---
    u = np.zeros(N)
    new_u = np.zeros(N)
    n_steps = 150 

    # --- Main Advect Loop ---
    for i_step in range(n_steps):
        # 1. Update Boundary (The Sine Pump)
        t = i_step * tau
        u[0] = np.sin(omega * t)
        
        # 2. Interior Update (Lax Logic)
        for i in range(1, N - 1):
            # Replaces u[i] with average of neighbors: Garcia Eq. (7.10)
            new_u[i] = 0.5 * (u[i+1] + u[i-1]) - 0.5 * coeff * (u[i+1] - u[i-1])
            
        # 3. Update active array and enforce Outflow
        u[1:N-1] = new_u[1:N-1]
        u[N-1] = u[N-2] 

    # --- Visualization ---
    plt.figure(figsize=(10, 5))
    plt.plot(x, u, 'r-', label='Lax Method (First-Order)')
    plt.axhline(0, color='black', alpha=0.3)
    plt.title(f"Exercise 7.4: Lax Scheme (Courant = {coeff:.3f})")
    plt.xlabel("Position x")
    plt.ylabel("Amplitude u")
    plt.legend()
    plt.grid(True)
    plt.show()









