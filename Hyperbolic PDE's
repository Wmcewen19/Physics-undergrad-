# ==============================================================================
# MCEWEN LABS: PROJECT 5 - EXERCISE 7.5
# SCHEME: UPWIND METHOD (LEFT-SIDED DERIVATIVE)
# ==============================================================================
# Purpose: To implement the directionally-biased Upwind scheme for the 1-D 
# Transport Equation, utilizing a left-sided spatial derivative for stability.
# ==============================================================================

def main():
    # --- Numerical Parameters ---
    N = 60                # Grid nodes
    L = 1.0               # Domain length
    x = np.linspace(0, L, N)
    h = L / (N - 1)       # Spatial step
    c = 1.0               # Advection velocity
    tau = 0.012           # Time step
    C = c * tau / h       # Courant Number (CFL condition)
    omega = 10 * np.pi    # Driving frequency
    
    # --- Initialization ---
    u = np.zeros(N)
    new_u = np.zeros(N)
    n_steps = 150 

    # --- Main Advect Loop (Upwind Logic) ---
    for i_step in range(n_steps):
        # Update Pump Boundary Condition (x=0)
        t = i_step * tau
        u[0] = np.sin(omega * t)
        
        # Interior Update: Garcia Problem 7.5 (Left Derivative)
        for i in range(1, N):
            # new_u[i] = u[i] - C * (u[i] - u[i-1])
            new_u[i] = u[i] - (c * tau / h) * (u[i] - u[i-1])
            
        # Update active array and enforce Outflow (Last point is handled by loop)
        u[1:] = new_u[1:]

    # --- Visualization ---
    plt.figure(figsize=(10, 6))
    plt.plot(x, u, color='forestgreen', linewidth=2, label='Upwind Scheme (First-Order)')
    plt.axhline(0, color='black', alpha=0.3)
    
    plt.title(f"Exercise 7.5: Upwind Method (Courant C = {C:.3f})")
    plt.xlabel("Position (x)")
    plt.ylabel("Amplitude (u)")
    plt.legend(loc='upper right')
    plt.grid(True, linestyle='--', alpha=0.6)
    
    plt.tight_layout()
    plt.show()

if __name__ == "__main__":
    main()









import numpy as np
