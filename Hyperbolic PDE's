import numpy as np
import matplotlib.pyplot as plt

# ==============================================================================
# MCEWEN LABS: PROJECT 5 - THE 18-PLOT ADVECTION ENGINE (MASTER ANALYSIS)
# ==============================================================================
# Purpose: A systematic evaluation of the 1-D Transport Equation across 
# three numerical schemes (FTCS, Lax, Lax-Wendroff). This script evaluates
# stability as a function of the Courant Number and Driving Frequency.
# ==============================================================================

# --- Global Grid Setup ---
N = 50                # Spatial nodes
L = 1.0               # Domain length [m]
x = np.linspace(0, L, N)
h = x[1] - x[0]       # Delta x
c = 1.0               # Advection velocity [m/s]

# --- Parameter Sweeps ---
taus = [0.015, 0.02, 0.03]            # Time steps (Varying Courant)
frequencies = [10 * np.pi, 20 * np.pi] # Driving frequencies (Normal vs. High)
schemes = ['FTCS', 'Lax', 'Lax-Wendroff']

def run_simulation(scheme, tau, omega):
    """
    Executes a single advection simulation for a given scheme and parameters.
    Returns the final state vector of the grid.
    """
    u = np.zeros(N)
    u_new = np.zeros(N)
    C = c * tau / h       # The Courant Number (CFL Stability Parameter)
    n_steps = int(1.2 / tau) 
    
    for step in range(n_steps):
        t = step * tau
        # Boundary Condition: The Sine Pump (Inflow at x=0)
        u[0] = np.sin(omega * t)
        
        # Interior Node Update Loop
        for i in range(1, N - 1):
            if scheme == 'FTCS':
                # Centered difference (Inherently unstable for advection)
                u_new[i] = u[i] - 0.5 * C * (u[i+1] - u[i-1])
            
            elif scheme == 'Lax':
                # Stabilized via Artificial Dissipation (Spatial Averaging)
                u_new[i] = 0.5 * (u[i+1] + u[i-1]) - 0.5 * C * (u[i+1] - u[i-1])
            
            elif scheme == 'Lax-Wendroff':
                # Second-order accurate correction (Non-dissipative)
                u_new[i] = (u[i] - 0.5 * C * (u[i+1] - u[i-1]) + 
                            0.5 * (C**2) * (u[i+1] - 2*u[i] + u[i-1]))
        
        # Enforce Outflow Boundary Condition
        u_new[N-1] = u_new[N-2]
        u[:] = u_new[:]
        
    return u, C

# --- The 18-Plot Matrix Visualization ---
fig, axes = plt.subplots(6, 3, figsize=(15, 22))
fig.suptitle("McEwen Labs: 18-Plot Stability & Convergence Analysis", fontsize=18, fontweight='bold')

row = 0
for omega in frequencies:
    for scheme in schemes:
        for i, tau in enumerate(taus):
            ax = axes[row, i]
            final_u, C = run_simulation(scheme, tau, omega)
            
            # Plotting the Final State
            ax.plot(x, final_u, linewidth=1.5)
            
            # Subplot Annotation
            ax.set_title(f"{scheme}\nC = {C:.2f} | ω = {omega/np.pi:.0f}π", fontsize=10)
            ax.set_ylim(-2.5, 2.5) # Bounds set to capture FTCS divergence
            ax.grid(True, linestyle='--', alpha=0.6)
            
            # Formatting labels
            if i == 0: ax.set_ylabel("Amplitude (u)")
            if row == 5: ax.set_xlabel("Position (x)")
            
        row += 1

plt.tight_layout(rect=[0, 0.03, 1, 0.96])
print("Simulations complete. Visualizing 18-plot matrix...")
plt.show()









