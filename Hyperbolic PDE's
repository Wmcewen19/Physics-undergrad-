# ==============================================================================
# MC-EWEN LABS: PROJECT 5 - EXERCISE 7.6
# SCHEME: LEAP-FROG (THREE-LEVEL SECOND-ORDER SCHEME)
# ==============================================================================
# Purpose: To implement the second-order Leap-Frog scheme. This method 
# minimizes numerical dissipation by using a centered-time derivative.
# ==============================================================================

def main():
    # --- Numerical Parameters ---
    N = 60
    L = 1.0
    x = np.linspace(0, L, N)
    h = L / (N - 1)
    c = 1.0
    tau = 0.01
    C = c * tau / h       # The Courant Number
    omega = 10 * np.pi
    n_steps = 150

    # --- Initialization ---
    # Leap-Frog requires three time levels: n-1, n, and n+1
    u_prev = np.zeros(N)  # Time step n-1
    u_curr = np.zeros(N)  # Time step n
    u_next = np.zeros(N)  # Time step n+1

    # --- 1. The Starter Step (Lax Method) ---
    # We use a single Lax step to generate the 'u_curr' from 'u_prev'
    u_prev[0] = np.sin(omega * 0)
    u_curr[0] = np.sin(omega * tau)
    
    for i in range(1, N - 1):
        # Lax update to kickstart the first interval
        u_curr[i] = 0.5*(u_prev[i+1] + u_prev[i-1]) - 0.5*C*(u_prev[i+1] - u_prev[i-1])

    # --- 2. Main Leap-Frog Loop ---
    for i_step in range(1, n_steps):
        # Update Pump Boundary Condition at the future time level
        t_next = (i_step + 1) * tau
        u_next[0] = np.sin(omega * t_next)
        
        # Leap-Frog Update: Center-Space, Center-Time (Garcia Eq 7.29)
        for i in range(1, N - 1):
            u_next[i] = u_prev[i] - C * (u_curr[i+1] - u_curr[i-1])
            
        # Enforce Outflow Boundary Condition
        u_next[N-1] = u_next[N-2]
        
        # Recursive Time-Shift: Move the window forward
        u_prev[:] = u_curr[:]
        u_curr[:] = u_next[:]

    # --- Visualization ---
    plt.figure(figsize=(10, 6))
    plt.plot(x, u_curr, color='darkviolet', linewidth=2, label='Leap-Frog Scheme')
    plt.axhline(0, color='black', alpha=0.3)
    
    plt.title(f"Exercise 7.6: Leap-Frog Method (Courant C = {C:.3f})")
    plt.xlabel("Position (x)")
    plt.ylabel("Amplitude (u)")
    plt.legend(loc='upper right')
    plt.grid(True, linestyle='--', alpha=0.6)
    
    plt.tight_layout()
    plt.show()

if __name__ == "__main__":
    main()
