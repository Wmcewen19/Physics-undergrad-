# =============================================================================
# MC-EWEN LABS: PROJECT 5 - EXERCISE 7.4 (PART B)
# SCHEME: LAX-WENDROFF (SECOND-ORDER ACCURACY)
# =============================================================================
# Purpose: To solve the 1-D Transport Equation using Lax-Wendroff logic,
# adding the second-order stabilization term (coeff^2).
# =============================================================================

def main():
    # --- Numerical Parameters ---
    N = 60
    L = 1.0
    x = np.linspace(0, L, N)
    h = L / (N - 1)
    c = 1.0
    tau = 0.012
    coeff = c * tau / h   # Courant number
    omega = 10 * np.pi
    
    # --- Initialization ---
    u = np.zeros(N)
    new_u = np.zeros(N)
    n_steps = 150 

    # --- Main Advect Loop ---
    for i_step in range(n_steps):
        # 1. Update Boundary
        t = i_step * tau
        u[0] = np.sin(omega * t)
        
        # 2. Interior Update (Lax-Wendroff Logic)
        for i in range(1, N - 1):
            # Second-order correction term: Garcia Eq. (7.18)
            new_u[i] = (u[i] - 0.5 * coeff * (u[i+1] - u[i-1]) + 
                        0.5 * (coeff**2) * (u[i+1] + u[i-1] - 2*u[i]))
            
        # 3. Update active array and enforce Outflow
        u[1:N-1] = new_u[1:N-1]
        u[N-1] = u[N-2] 

    # --- Visualization ---
    plt.figure(figsize=(10, 5))
    plt.plot(x, u, 'b-', label='Lax-Wendroff (Second-Order)')
    plt.axhline(0, color='black', alpha=0.3)
    plt.title(f"Exercise 7.4: Lax-Wendroff Scheme (Courant = {coeff:.3f})")
    plt.xlabel("Position x")
    plt.ylabel("Amplitude u")
    plt.legend()
    plt.grid(True)
    plt.show()

if __name__ == "__main__":
    main()

