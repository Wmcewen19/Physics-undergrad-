import numpy as np
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D

# ==============================================================================
# MCEWEN LABS: PROJECT 6 - EXERCISE 1 (PROBLEM 8.1)
# SCHEME: 2D JACOBI RELAXATION (THE BASELINE SOLVER)
# ==============================================================================
# Purpose: To solve the 2D Laplace Equation (grad^2 Phi = 0) on a 50x50 grid.
# This serves as our fundamental baseline for the project, modeling a 
# conducting box where the top plate is hot (1.0V) and the others are grounded.
# ==============================================================================

def main():
    # --- Physical & Numerical Parameters ---
    N = 50                # Grid resolution (50x50)
    phi_top = 1.0         # Boundary potential (Volts)
    iter_max = 5000       # Safety cap for iterations
    tolerance = 1e-4      # Garcia's fractional change threshold
    
    # --- Grid Initialization ---
    # phi: The active potential map | new_phi: The buffer for simultaneous updates
    phi = np.zeros((N, N))
    
    # Apply Dirichlet Boundary Condition: Top edge (index 0) is held at 1.0V
    phi[0, :] = phi_top  
    
    new_phi = np.copy(phi)
    
    print(f" 2D Jacobi Solver on {N}x{N} grid...")

    # --- Main Iterative Loop (The Relaxation Routine) ---
    for i_iter in range(1, iter_max + 1):
        # We perform the Jacobi update: Every point is the average of its 4 neighbors.
        # Vectorized slicing makes this way faster than a nested 'for' loop.
        new_phi[1:-1, 1:-1] = 0.25 * (phi[2:, 1:-1] + phi[:-2, 1:-1] + 
                                       phi[1:-1, 2:] + phi[1:-1, :-2])
        
        # --- Garcia's Convergence Metric ---
        # We check the average fractional change to see if the system is at equilibrium.
        mask = new_phi != 0
        diff = np.sum(np.abs(1 - phi[mask] / new_phi[mask]))
        fractional_change = diff / (N - 2)**2
        
        # Simultaneous Update: Shift the buffer into the active grid
        phi[:] = new_phi[:]
        
        if fractional_change < tolerance:
            print(f"Status: 2D Convergence achieved at {i_iter} iterations.")
            break
    else:
        print("Warning: Max iterations reached. Equilibrium not fully established.")

    # --- High-Fidelity Visualization (The "Smoking Gun" Plots) ---
    # We need both a contour map and a 3D mesh surface to satisfy Garcia 8.1.
    
    fig = plt.figure(figsize=(14, 6))

    # Plot 1: 2D Contour Map (The Top-Down View)
    ax1 = fig.add_subplot(121)
    cont = ax1.contourf(phi, levels=50, cmap='magma')
    fig.colorbar(cont, ax=ax1, label=r'Potential $\Phi$ [V]')
    ax1.set_title("Problem 8.1: 2D Potential Contour Map")
    ax1.set_xlabel("x-index")
    ax1.set_ylabel("y-index")
    ax1.invert_yaxis() # Match the physical "Top Plate" orientation

    # Plot 2: 3D Mesh Surface (The "Mountain" View)
    ax2 = fig.add_subplot(122, projection='3d')
    X, Y = np.meshgrid(np.arange(N), np.arange(N))
    surf = ax2.plot_surface(X, Y, phi, cmap='magma', edgecolor='black', lw=0.1)
    ax2.set_title("Problem 8.1: 3D Potential Mesh Surface")
    ax2.set_zlabel(r"Potential $\Phi$ (V)")
    ax2.view_init(elev=30, azim=45) # Angle it so we can see the "downhill" slope

    plt.tight_layout()
    plt.show()

if __name__ == "__main__":
    main()








import numpy as np
