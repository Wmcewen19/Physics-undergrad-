# ==============================================================================
# MCEWEN LABS: PROJECT 6 - EXERCISE 2 (PROBLEM 8.3)
# SCHEME: 3D JACOBI VOLUMETRIC RELAXATION (THE CUBIC SOLVER)
# ==============================================================================
# Purpose: To solve the 3D Laplace Equation (grad^2 Phi = 0) within a cubic 
# volume. We’re modeling a conducting box with a 1.0V ceiling and grounded 
# walls/floor. This is the high-fidelity version of our baseline 2D solver.
# ==============================================================================

def main():
    # --- Physical & Numerical Parameters ---
    N = 15                # Grid resolution per dimension (15x15x15)
    phi_top = 1.0         # Boundary potential (Volts) on the z=L face
    iter_max = 2000       # Safety cap for the volumetric crunch
    tolerance = 1e-4      # Garcia's target fractional change metric
    
    # --- 3D Grid Initialization ---
    # phi[z, y, x] mapping: We initialize the volume to zero and pin the ceiling.
    phi = np.zeros((N, N, N))
    phi[0, :, :] = phi_top  # Dirichlet Boundary: Top face index at 1.0V
    
    new_phi = np.copy(phi)
    
    print(f"McEwen Labs: Initiating 3D Volumetric Solver on {N}^3 grid...")

    # --- Main Iterative Loop (The 3D Relax Routine) ---
    for i_iter in range(1, iter_max + 1):
        
        # 3D Jacobi Rule: Every interior node is the average of 6 cardinal neighbors.
        # Vectorized slicing: (Up/Down, Left/Right, Front/Back)
        new_phi[1:-1, 1:-1, 1:-1] = (1/6.0) * (
            phi[2:, 1:-1, 1:-1] + phi[:-2, 1:-1, 1:-1] + # Z-axis neighbors
            phi[1:-1, 2:, 1:-1] + phi[1:-1, :-2, 1:-1] + # Y-axis neighbors
            phi[1:-1, 1:-1, 2:] + phi[1:-1, 1:-1, :-2]   # X-axis neighbors
        )
        
        # --- Garcia's Convergence Metric ---
        # Checking normalized fractional change across the entire 3D volume.
        mask = new_phi != 0
        diff = np.sum(np.abs(1 - phi[mask] / new_phi[mask]))
        fractional_change = diff / (N - 2)**3
        
        # Simultaneous Update: Moving the buffer into the active grid
        phi[:] = new_phi[:]
        
        if fractional_change < tolerance:
            print(f"McEwen Labs Status: 3D Convergence reached at {i_iter} iterations.")
            break
    else:
        print("Warning: System did not reach equilibrium within iteration limit.")

    # --- High-Fidelity Visualization (Garcia 3b Compliance) ---
    mid = N // 2
    qtr = N // 4
    
    # Plotting Part 1: The Dual Contour Slices (r'...' raw strings for LaTeX)
    fig1, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))
    
    # Mid-plane (L/2)
    p1 = ax1.contourf(phi[mid, :, :], levels=50, cmap='inferno')
    fig1.colorbar(p1, ax=ax1, label=r'Potential $\Phi$ [V]')
    ax1.set_title(r"3D Potential Slice: $z = L/2$")
    ax1.set_xlabel("x-index"); ax1.set_ylabel("y-index")
    ax1.invert_yaxis()

    # Quarter-plane (L/4)
    p2 = ax2.contourf(phi[qtr, :, :], levels=50, cmap='inferno')
    fig1.colorbar(p2, ax=ax2, label=r'Potential $\Phi$ [V]')
    ax2.set_title(r"3D Potential Slice: $z = L/4$")
    ax2.set_xlabel("x-index"); ax2.set_ylabel("y-index")
    ax2.invert_yaxis()
    
    plt.tight_layout()
    plt.show()

    # Plotting Part 2: The Mesh Surface (The 3D "Mountain")
    # Using specific padding and view angles to prevent label cut-off.
    fig2 = plt.figure(figsize=(11, 9))
    ax3 = fig2.add_subplot(111, projection='3d')
    X, Y = np.meshgrid(np.arange(N), np.arange(N))
    
    surf = ax3.plot_surface(X, Y, phi[mid, :, :], cmap='inferno', edgecolor='black', lw=0.1)
    
    ax3.set_title(r"3D Potential Mesh Surface at $z = L/2$", fontsize=14, pad=20)
    ax3.set_xlabel("x-index", labelpad=10)
    ax3.set_ylabel("y-index", labelpad=10)
    
    # FIX: Added labelpad to ensure Z-axis text doesn't clip
    ax3.set_zlabel(r"Potential $\Phi$ (V)", labelpad=15)
    
    # Set view for maximum depth perception
    ax3.view_init(elev=25, azim=45)
    
    fig2.colorbar(surf, ax=ax3, shrink=0.5, aspect=12, pad=0.1)
    
    plt.show()

if __name__ == "__main__":
    main()









import numpy as np
import matplotlib.pyplot as plt

# ==============================================================================
# MCEWEN LABS: PROJECT 6 - EXERCISE 3 (PROBLEM 8.4)
# SCHEME: AUTOMATED SCALING SWEEP & POWER-LAW ANALYSIS
# ==============================================================================
# Purpose: To empirically prove the O(N^2) computational penalty of the 
# Jacobi method. This script sweeps through multiple grid resolutions and 
# extracts the scaling exponent using a log-log regression.
# ==============================================================================

def jacobi_solver(N):
    """
    Core engine that runs the relaxation for a specific grid size (N)
    and returns the total iteration count until steady-state.
    """
    phi = np.zeros((N, N))
    phi[0, :] = 1.0  # Dirichlet BC: High potential top plate
    new_phi = np.copy(phi)
    
    # Safety limit to prevent infinite loops during testing
    for it in range(1, N**3):
        change_sum = 0
        
        # Interior Node Update: Averaging the 4 cardinal neighbors
        for i in range(1, N - 1):
            for j in range(1, N - 1):
                new_phi[i, j] = 0.25 * (phi[i+1, j] + phi[i-1, j] + 
                                        phi[i, j+1] + phi[i, j-1])
                
                # Garcia's Fractional Change Metric
                if new_phi[i, j] != 0:
                    change_sum += abs(1 - phi[i, j] / new_phi[i, j])
        
        # Normalize error across all interior points
        fractional_change = change_sum / (N - 2)**2
        phi[:] = new_phi[:]
        
        if fractional_change < 1e-4:
            return it
            
    return N**3

def main():
    # --- Experimental Parameters ---
    grid_sizes = np.array([10, 20, 30, 40, 50])
    iterations = []

    print("McEwen Labs: Initiating Automated Grid-Scaling Sweep...")
    
    for N in grid_sizes:
        count = jacobi_solver(N)
        iterations.append(count)
        print(f"  > Grid {N}x{N} reached equilibrium in {count} iterations.")

    iterations = np.array(iterations)

    # --- Power-Law Math: Extracting the Exponent ---
    # log(Iter) = a * log(N) + C. Slope 'a' is our scaling exponent.
    params = np.polyfit(np.log(grid_sizes), np.log(iterations), 1)
    exponent = params[0]
    
    print("-" * 50)
    print(f"CALCULATED SCALING EXPONENT: {exponent:.3f}")
    print("-" * 50)

    # --- High-Fidelity Scaling Plot ---
    plt.figure(figsize=(10, 6))
    
    # FIX: Explicitly defined marker='s' (squares) and linestyle='' to avoid errors
    plt.loglog(grid_sizes, iterations, marker='s', linestyle='', color='blue', 
               markersize=8, label='Experimental Jacobi Data')
    
    # Plot the line of best fit (theoretical path)
    fit_line = np.exp(np.polyval(params, np.log(grid_sizes)))
    plt.loglog(grid_sizes, fit_line, color='crimson', linestyle='--', 
               label=f'Power Law Fit ($N^{{{exponent:.2f}}}$)')

    plt.title("Exercise 8.4: Jacobi Convergence Scaling Analysis", fontsize=14)
    plt.xlabel("Grid Resolution (N)", fontsize=12)
    plt.ylabel("Iterations to Converge", fontsize=12)
    plt.grid(True, which="both", ls="-", alpha=0.2)
    plt.legend()
    plt.tight_layout()
    plt.show()

if __name__ == "__main__":
    main()









import numpy as np
import matplotlib.pyplot as plt

# ==============================================================================
# MCEWEN LABS: PROJECT 6 - PROBLEM 4 (EXERCISE 8.7)
# SCHEME: DUAL-MODE ELECTRIC FIELD MAPPING (PROPORTIONAL vs. NORMALIZED)
# ==============================================================================
# Purpose: Transform scalar potential into vector force fields.
# Specs: High-contrast heatmap, proportional scaling, and unit-length flow.
# ==============================================================================

def main():
    # --- Step 1: Potential Field Generation (Baseline 8.1) ---
    N = 50
    phi = np.zeros((N, N))
    phi[0, :] = 1.0  # Dirichlet BC: Top plate held at 1.0V
    new_phi = np.copy(phi)
    
    # Jacobi Relaxation Engine
    for it in range(1, 4001):
        new_phi[1:-1, 1:-1] = 0.25 * (phi[2:, 1:-1] + phi[:-2, 1:-1] + 
                                       phi[1:-1, 2:] + phi[1:-1, :-2])
        if np.max(np.abs(phi - new_phi)) < 1e-5:
            break
        phi[:] = new_phi[:]

    # --- Step 2: Vector Calculus (E = -grad Phi) ---
    # np.gradient returns [dPhi/dy, dPhi/dx] for 2D arrays
    Ey, Ex = np.gradient(-phi) 
    magnitude = np.sqrt(Ex**2 + Ey**2)

    # --- Step 3: High-Fidelity Dual Visualization ---
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 8))
    X, Y = np.meshgrid(np.arange(N), np.arange(N))
    skip = (slice(None, None, 3), slice(None, None, 3)) # Arrow density per Garcia spec

    # Metadata for the "McEwen Labs" Spec
    print("McEwen Labs: Computing Dual-Mode Potential Gradient...")
    print(f"Convergence achieved at {it} iterations.")

    # --- PLOT A: PROPORTIONAL ARROWS (Intensity Map) ---
    # Arrows scale with field strength (Longer at top, tiny at bottom)
    im1 = ax1.imshow(phi, cmap='magma', origin='upper', extent=[0, N, N, 0])
    ax1.quiver(X[skip], Y[skip], Ex[skip], Ey[skip], 
               color='white', pivot='mid', scale=1.0)
    ax1.set_title(r"A: Proportional Field Map ($|\vec{E}|$ scaling)")
    ax1.set_xlabel("Grid index (x)"); ax1.set_ylabel("Grid index (y)")
    fig.colorbar(im1, ax=ax1, label=r'Potential $\Phi$ [V]', fraction=0.046, pad=0.04)

    # --- PLOT B: NORMALIZED ARROWS (Direction/Flow Map) ---
    # Arrows are equal length to show direction in low-field zones
    Ex_unit = np.where(magnitude > 0, Ex / magnitude, 0)
    Ey_unit = np.where(magnitude > 0, Ey / magnitude, 0)
    
    im2 = ax2.imshow(phi, cmap='magma', origin='upper', extent=[0, N, N, 0])
    ax2.quiver(X[skip], Y[skip], Ex_unit[skip], Ey_unit[skip], 
               color='white', pivot='mid', scale=25, width=0.004)
    ax2.set_title(r"B: Normalized Direction Field ($\vec{E}/|\vec{E}|$)")
    ax2.set_xlabel("Grid index (x)"); ax2.set_ylabel("Grid index (y)")
    fig.colorbar(im2, ax=ax2, label=r'Potential $\Phi$ [V]', fraction=0.046, pad=0.04)

    plt.suptitle(r"Problem 4 (8.7): Electric Field Vector Analysis ($\vec{E} = -\nabla \Phi$)", fontsize=16)
    plt.tight_layout(rect=[0, 0.03, 1, 0.95])
    plt.show()

if __name__ == "__main__":
    main()









import numpy as np
import matplotlib.pyplot as plt

# ==============================================================================
# MCEWEN LABS: PROJECT 6 - PROBLEM 8.10 (POISSON SOLVER)
# SCHEME: SUCCESSIVE OVER-RELAXATION (SOR) - THE FINALE
# ==============================================================================

def main():
    # --- Physical & Numerical Parameters ---
    N = 50                # Grid resolution
    rho_val = 10.0        # Source term at center
    tolerance = 1e-4      
    omega = 2 / (1 + np.pi / N)  # Optimal relaxation parameter
    
    phi = np.zeros((N, N))
    
    print(f"McEwen Labs: SOR Engine Active. Optimal Omega = {omega:.4f}")

    # --- SOR Iterative Routine ---
    for i_iter in range(1, 5001):
        max_diff = 0
        
        for i in range(1, N - 1):
            for j in range(1, N - 1):
                # SOURCE CENTERING: Dead center at index 25
                source = rho_val if (i == N//2 and j == N//2) else 0
                
                # Standard 4-neighbor average + Poisson source
                phi_new = 0.25 * (phi[i+1,j] + phi[i-1,j] + 
                                  phi[i,j+1] + phi[i,j-1] + source)
                
                # SOR weight adjustment
                residual = phi_new - phi[i,j]
                phi[i,j] += omega * residual
                
                if abs(residual) > max_diff:
                    max_diff = abs(residual)
        
        if max_diff < tolerance:
            print(f"McEwen Labs Status: Convergence achieved at {i_iter} iterations.")
            break

    # --- Clean Visualization ---
    plt.figure(figsize=(10, 8), dpi=150) # Higher DPI for crispness
    
    # Heatmap with Bilinear Interpolation for a smooth, non-grainy gradient
    im = plt.imshow(phi, cmap='magma', origin='upper', extent=[0, N, N, 0], 
                    interpolation='bilinear')
    
    plt.colorbar(im, label=r'Potential $\Phi$ [V]', fraction=0.046, pad=0.04)
    
    # Add Equipotential Contours
    plt.contour(phi, levels=15, colors='white', alpha=0.15, linewidths=0.5)
    
    # THE CRITICAL FIX: raw f-string (rf"") kills SyntaxWarnings for good
    title_str = (rf"Problem 8.10: Poisson Potential (Shielded Line Charge)" + 
                 rf"\nSOR Method | $\omega$: {omega:.2f} | Iterations: {i_iter}")
    plt.title(title_str, fontsize=12)
    
    plt.xlabel("Grid index (x)")
    plt.ylabel("Grid index (y)")
    
    # Subtle grid overlay
    plt.grid(True, which='both', color='white', linestyle='-', linewidth=0.5, alpha=0.1)
    
    plt.tight_layout()
    plt.show()

if __name__ == "__main__":
    main()




